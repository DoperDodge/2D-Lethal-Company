{
  "name": "quota",
  "private": true,
  "version": "0.1.0",
  "description": "2D top-down co-op horror salvage game inspired by Lethal Company",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all -s build:shared -p dev:shared dev:server dev:client",
    "dev:shared": "npm --workspace shared run watch",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build:shared": "npm --workspace shared run build",
    "build": "npm run build:shared && npm --workspace server run build && npm --workspace client run build",
    "start": "npm --workspace server run start",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
